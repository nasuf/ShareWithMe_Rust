# Use 127.0.0.1:8080 for local-only desktop/simulator testing.
# Use 0.0.0.0:8080 when a real phone needs to reach this backend over LAN.
SHARE_WITH_ME_BIND=0.0.0.0:8080
SHARE_WITH_ME_STORE_BACKEND=supabase
SHARE_WITH_ME_STORE=share_with_me_store.json
SHARE_WITH_ME_MEDIA=media

DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
# Prefer setting this in your shell or key.txt. Do not commit real keys.
# DEEPSEEK_API_KEY=

# Backend storage uses a Postgres connection through Supabase's IPv4 pooler.
# You may set SUPABASE_DATABASE_URL directly instead of the fields below.
# SUPABASE_DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_REGION=ap-south-1
SUPABASE_DB_PORT=5432
SUPABASE_PASSWORD=<database-password>

# Keep client/API keys out of git; use GitHub Secrets or local .env when needed.
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
# SUPABASE_JWKS_URL=
